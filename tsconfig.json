{
  "compilerOptions": {
    "lib": ["ES6"],
    "module": "ESNext",
    "target": "ES6",
    "strict": true,
    "esModuleInterop": true,
    "moduleResolution": "bundler",
    "rootDir": "./src",
    "outDir": "./lib",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "types": ["node"]
  },
  "include": ["src"],
  "exclude": ["node_modules", "lib", "tsup.config.ts", "src/@types/partial-nullable.ts"]
}
